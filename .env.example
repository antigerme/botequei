# Botequei — exemplo de configuracao. Copie para ".env" e preencha.
#
# ⚠️  NUNCA comite o .env (ja esta no .gitignore).
# ⚠️  Recomendado: deixe o .env FORA do docroot (uma pasta acima do site).
#     O turn.php procura primeiro em ../.env justamente por isso.
#     Se optar por deixar ao lado, BLOQUEIE o acesso web ao .env no servidor:
#       Apache:  <Files ".env"> Require all denied </Files>
#       nginx:   location ~ /\.env { deny all; }
#
# Credenciais do Cloudflare TURN (opcional — sem elas, o app usa so STUN):
CF_TURN_KEY_ID=
CF_TURN_API_TOKEN=
# CF_TURN_TTL=86400
