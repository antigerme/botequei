# Botequei — exemplo de .htaccess (Apache). Copie para ".htaccess" e preencha.
#
# ✅ Vantagem: o Apache, por padrao, NAO serve arquivos .ht* (regra "Require all denied"
#    da config padrao), entao por o segredo aqui NAO vaza pela web — diferente do .env.
# ⚠️ Mesmo assim, NAO comite o .htaccess com segredos (ja esta no .gitignore).
# ⚠️ Precisa de "AllowOverride" habilitado (padrao na maioria das hospedagens compartilhadas).

# --- Credenciais do Cloudflare TURN ---
# Vao para o ambiente do PHP (lidas pelo turn.php via $_SERVER, em mod_php e php-fpm).
SetEnv CF_TURN_KEY_ID seu_key_id
SetEnv CF_TURN_API_TOKEN seu_api_token
# SetEnv CF_TURN_TTL 86400

# --- Defesa extra: se voce deixar um .env NA pasta do site, bloqueie o acesso web a ele ---
<Files ".env">
    Require all denied
</Files>

# --- Desligar o mod_pagespeed neste app ---
# PageSpeed pode quebrar ES modules e o service worker de um PWA. O Botequei ja e enxuto
# (sem build), entao nao ha o que otimizar. Se o servidor tiver PageSpeed, desligue aqui.
<IfModule pagespeed_module>
    ModPagespeed off
</IfModule>

# --- Cache: evita "mistura de versoes" dos ES modules atras de CDN (Cloudflare) ---
# Os modulos NAO tem hash no nome. Se o CDN/navegador servir um .js velho junto de um novo,
# o app quebra ("does not provide an export named ..."). Solucao: HTML, sw.js, .js e .css
# usam "no-cache" (pode guardar, mas SEMPRE revalida -> 304 barato, nunca versao velha). O
# service worker continua guardando tudo pra offline; aqui so garantimos o frescor na rede.
# Fontes/icones sao estaveis -> cache longo.
<IfModule mod_headers.c>
    <FilesMatch "\.(html|webmanifest)$">
        Header set Cache-Control "no-cache"
    </FilesMatch>
    <Files "sw.js">
        Header set Cache-Control "no-cache"
    </Files>
    <FilesMatch "\.(js|mjs|css)$">
        Header set Cache-Control "no-cache"
    </FilesMatch>
    <FilesMatch "\.(woff2|png|svg|ico|jpg|jpeg|webp)$">
        Header set Cache-Control "public, max-age=604800"
    </FilesMatch>
</IfModule>

# --- Bloquear utilitarios de build/testes do acesso web ---
RedirectMatch 404 ^/tools/
RedirectMatch 404 ^/tests/
